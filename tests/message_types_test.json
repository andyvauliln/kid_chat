{
  "description": "Test cases for message router.",
  "notes": {
    "response_rule": "response should be null for all intents except request_translate",
    "daily_report_rule": "Only daily_reports uses needs_llm=false with what field containing exact text",
    "other_files_rule": "All other files use needs_llm=true with llm_prompt containing instruction for LLM",
    "message_en_rule": "AI translates and formats, we don't check equality"
  },
  "test_cases": [
    {
      "id": "T01",
      "name": "Simple food report - no preference",
      "input": {
        "username": "Hirja",
        "message_raw": "Dante makan 2 telur dan pisang pagi ini"
      },
      "expected": {
        "needs_context": false,
        "response": null,
        "context_files_must_include": []
      }
    },
    {
      "id": "T02",
      "name": "Video watched - liked",
      "input": {
        "username": "Hirja",
